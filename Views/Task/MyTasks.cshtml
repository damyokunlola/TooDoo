@{
    ViewData["Title"] = "My Tasks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model List<TooDooList.Models.TaskItem>

<div class="container">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>My Tasks</h1>
        </div>
        <div class="col-md-4 text-right">
            <a href="/Task/Create" class="btn btn-primary">+ Create New Task</a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Created Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model)
                    {
                        string statusBadgeClass = task.Status switch
                        {
                            TooDooList.Models.TaskStatus.Completed => "badge-success",
                            TooDooList.Models.TaskStatus.Ongoing => "badge-warning",
                            TooDooList.Models.TaskStatus.Cancelled => "badge-danger",
                            _ => "badge-secondary"
                        };

                        <tr>
                            <td>
                                <strong>@task.Title</strong>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(task.Description))
                                {
                                    if (task.Description.Length > 50)
                                    {
                                        @task.Description.Substring(0, 50)<text>...</text>
                                    }
                                    else
                                    {
                                        @task.Description
                                    }
                                }
                            </td>
                            <td>
                                <span class="badge @statusBadgeClass">@task.Status</span>
                            </td>
                            <td>
                                @task.CreatedDate.ToString("MMM dd, yyyy")
                            </td>
                            <td>
                                <a href="@Url.Action("Details", "Task", new { id = task.Id })" class="btn btn-sm btn-info">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Task Details Modals -->
        @foreach (var task in Model)
        {
            <div class="modal fade" id="taskModal@(task.Id)" tabindex="-1" role="dialog">
                <div class="modal-dialog" role="document">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@task.Title</h5>
                            <button type="button" class="close" data-dismiss="modal">
                                <span>&times;</span>
                            </button>
                        </div>
                        <div class="modal-body">
                            <p><strong>Description:</strong></p>
                            <p>@(string.IsNullOrEmpty(task.Description) ? "No description provided" : task.Description)</p>
                            
                            @{
                                string statusBadgeClass = task.Status switch
                                {
                                    TooDooList.Models.TaskStatus.Completed => "badge bg-success",
                                    TooDooList.Models.TaskStatus.Ongoing => "badge bg-warning text-dark",
                                    TooDooList.Models.TaskStatus.Cancelled => "badge bg-danger",
                                    _ => "badge bg-secondary"
                                };
                            }
                            
                            <p><strong>Status:</strong> <span class="@statusBadgeClass">@task.Status</span></p>
                            <p><strong>Created:</strong> @task.CreatedDate.ToString("MMMM dd, yyyy HH:mm")</p>
                            @if (task.CompletedDate.HasValue)
                            {
                                <p><strong>Completed:</strong> @task.CompletedDate.Value.ToString("MMMM dd, yyyy HH:mm")</p>
                            }
                            
                            @if (task.Status == TooDooList.Models.TaskStatus.Completed)
                            {
                                <div class="alert alert-info mt-3">
                                    <i class="bi bi-info-circle"></i> Completed tasks cannot be updated.
                                </div>
                            }
                        </div>
                        <div class="modal-footer">
                            @if (task.Status != TooDooList.Models.TaskStatus.Completed)
                            {
                                <a href="@Url.Action("Update", "Task", new { id = task.Id })" class="btn btn-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            }
                            <a href="@Url.Action("Details", "Task", new { id = task.Id })" class="btn btn-secondary">
                                <i class="bi bi-eye"></i> Full Details
                            </a>
                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info text-center">
            <h5>No tasks yet!</h5>
            <p>Create your first task to get started.</p>
            <a href="/Task/Create" class="btn btn-primary">Create Task</a>
        </div>
    }
</div>
