@{
    ViewData["Title"] = "Booking Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model TooDooList.Models.ServiceBooking

<div class="container mt-5 mb-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow-lg">
                <div class="card-header" style="background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%); color: white; border: none;">
                    <div class="d-flex justify-content-between align-items-center">
                        <h2 class="mb-0"><i class="fas fa-info-circle"></i> Booking Details</h2>
                        <div>
                            @switch(Model.Status)
                            {
                                case TooDooList.Models.BookingStatus.Start:
                                    <span class="badge" style="background-color: #e74c3c; padding: 8px 12px; font-size: 0.95em;">Pending</span>
                                    break;
                                case TooDooList.Models.BookingStatus.InProgress:
                                    <span class="badge" style="background-color: #f39c12; padding: 8px 12px; font-size: 0.95em;">In Progress</span>
                                    break;
                                case TooDooList.Models.BookingStatus.Completed:
                                    <span class="badge" style="background-color: #3498db; padding: 8px 12px; font-size: 0.95em;">Completed</span>
                                    break;
                                case TooDooList.Models.BookingStatus.Cancelled:
                                    <span class="badge" style="background-color: #95a5a6; padding: 8px 12px; font-size: 0.95em;">Cancelled</span>
                                    break;
                            }
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-1">Service Name</h6>
                            <h5 class="mb-3">@Model.ServiceName</h5>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted mb-1">Service Type</h6>
                            <h5 class="mb-3" style="color: #2ecc71;">@Model.ServiceType.ToString()</h5>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-1"><i class="fas fa-calendar"></i> Scheduled Date</h6>
                            <p class="mb-3"><strong>@Model.ScheduledDate.ToString("dddd, MMMM dd, yyyy HH:mm")</strong></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted mb-1"><i class="fas fa-dollar-sign"></i> Price</h6>
                            <p class="mb-3"><strong style="font-size: 1.2em;">$@Model.Price.ToString("F2")</strong></p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12">
                            <h6 class="text-muted mb-1"><i class="fas fa-map-marker-alt"></i> Service Address</h6>
                            <p class="mb-3"><strong>@Model.Address</strong></p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="row mb-4">
                            <div class="col-md-12">
                                <h6 class="text-muted mb-1"><i class="fas fa-notes-medical"></i> Service Details</h6>
                                <p class="mb-3">@Model.Description</p>
                            </div>
                        </div>
                    }

                    <hr class="my-4" />

                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-1">Created Date</h6>
                            <p>@Model.CreatedDate.ToString("MMMM dd, yyyy HH:mm")</p>
                        </div>
                        @if (Model.CompletedDate.HasValue)
                        {
                            <div class="col-md-6">
                                <h6 class="text-muted mb-1">Completed Date</h6>
                                <p>@Model.CompletedDate.Value.ToString("MMMM dd, yyyy HH:mm")</p>
                            </div>
                        }
                        @if (Model.CancelledDate.HasValue)
                        {
                            <div class="col-md-6">
                                <h6 class="text-muted mb-1">Cancelled Date</h6>
                                <p>@Model.CancelledDate.Value.ToString("MMMM dd, yyyy HH:mm")</p>
                            </div>
                        }
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-between mt-5">
                        <div>
                            @if (Model.Status != TooDooList.Models.BookingStatus.Cancelled && 
                                 Model.Status != TooDooList.Models.BookingStatus.Completed)
                            {
                                <a href="/Booking/Update/@Model.Id" class="btn btn-warning btn-lg">
                                    <i class="fas fa-edit"></i> Edit Booking
                                </a>
                                <form method="post" action="/Booking/CancelBooking/@Model.Id" style="display: inline;">
                                    <button type="submit" class="btn btn-danger btn-lg" onclick="return confirm('Are you sure you want to cancel this booking?');">
                                        <i class="fas fa-times"></i> Cancel Booking
                                    </button>
                                </form>
                            }
                        </div>
                        <a href="/Booking/MyBookings" class="btn btn-outline-primary btn-lg">
                            <i class="fas fa-arrow-left"></i> Back to Bookings
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
