@{
    ViewData["Title"] = "Task Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model TooDooList.Models.TaskItem

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @if (!string.IsNullOrEmpty(ViewData["ErrorMessage"]?.ToString()))
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @ViewData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (!string.IsNullOrEmpty(ViewData["SuccessMessage"]?.ToString()))
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @ViewData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4>@Model.Title</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p><strong>Status:</strong></p>
                            @{
                                string statusBadgeClass = Model.Status switch
                                {
                                    TooDooList.Models.TaskStatus.Completed => "badge bg-success",
                                    TooDooList.Models.TaskStatus.Ongoing => "badge bg-warning text-dark",
                                    TooDooList.Models.TaskStatus.Cancelled => "badge bg-danger",
                                    _ => "badge bg-secondary"
                                };
                            }
                            <span class="@statusBadgeClass" style="font-size: 14px; padding: 6px 12px;">@Model.Status</span>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Created Date:</strong></p>
                            <p>@Model.CreatedDate.ToString("MMMM dd, yyyy HH:mm")</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-12">
                            <p><strong>Description:</strong></p>
                            <p class="border-start ps-3">
                                @if (!string.IsNullOrEmpty(Model.Description))
                                {
                                    @Model.Description
                                }
                                else
                                {
                                    <em class="text-muted">No description provided</em>
                                }
                            </p>
                        </div>
                    </div>

                    @if (Model.CompletedDate.HasValue)
                    {
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <p><strong>Completed Date:</strong></p>
                                <p>@Model.CompletedDate.Value.ToString("MMMM dd, yyyy HH:mm")</p>
                            </div>
                        </div>
                    }
                </div>

                <div class="card-footer bg-light">
                    @if (Model.Status != TooDooList.Models.TaskStatus.Completed)
                    {
                        <a href="@Url.Action("Update", "Task", new { id = Model.Id })" class="btn btn-primary">
                            <i class="bi bi-pencil"></i> Edit Task
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-primary" disabled title="Completed tasks cannot be edited">
                            <i class="bi bi-pencil"></i> Edit Task
                        </button>
                    }

                    <a href="@Url.Action("MyTasks", "Task")" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Tasks
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
