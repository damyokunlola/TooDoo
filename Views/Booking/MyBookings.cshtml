@{
    ViewData["Title"] = "My Bookings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model List<TooDooList.Models.ServiceBooking>

<div class="container mt-5 mb-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5" style="color: #2ecc71;"><i class="fas fa-list-check"></i> My Bookings</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Booking/Create" class="btn btn-success btn-lg" style="background-color: #2ecc71; border: none;">
                <i class="fas fa-plus"></i> New Booking
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-inbox" style="font-size: 3em; color: #3498db; margin-bottom: 15px;"></i>
            <h4>No bookings yet</h4>
            <p>Start by creating your first cleaning service booking.</p>
            <a href="/Booking/Create" class="btn btn-primary mt-3">Create Booking</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var booking in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100" style="border-top: 4px solid #2ecc71;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="card-title mb-1">@booking.ServiceName</h5>
                                    <span class="badge badge-info" style="background-color: #3498db; padding: 6px 10px; font-size: 0.85em;">
                                        @booking.ServiceType.ToString()
                                    </span>
                                </div>
                                <div class="text-end">
                                    @switch(booking.Status)
                                    {
                                        case TooDooList.Models.BookingStatus.Start:
                                            <span class="badge" style="background-color: #e74c3c; padding: 6px 10px; font-size: 0.85em;">Pending</span>
                                            break;
                                        case TooDooList.Models.BookingStatus.InProgress:
                                            <span class="badge" style="background-color: #f39c12; padding: 6px 10px; font-size: 0.85em;">In Progress</span>
                                            break;
                                        case TooDooList.Models.BookingStatus.Completed:
                                            <span class="badge" style="background-color: #3498db; padding: 6px 10px; font-size: 0.85em;">Completed</span>
                                            break;
                                        case TooDooList.Models.BookingStatus.Cancelled:
                                            <span class="badge" style="background-color: #95a5a6; padding: 6px 10px; font-size: 0.85em;">Cancelled</span>
                                            break;
                                    }
                                </div>
                            </div>

                            <div class="card-text mb-3">
                                <p class="mb-2"><strong><i class="fas fa-calendar"></i> Scheduled:</strong> @booking.ScheduledDate.ToString("MMMM dd, yyyy HH:mm")</p>
                                <p class="mb-2"><strong><i class="fas fa-map-marker-alt"></i> Address:</strong> @booking.Address</p>
                                <p class="mb-2"><strong><i class="fas fa-dollar-sign"></i> Price:</strong> $@booking.Price.ToString("F2")</p>
                                @if (!string.IsNullOrEmpty(booking.Description))
                                {
                                    <p class="mb-2 text-muted">@booking.Description.Substring(0, Math.Min(100, booking.Description.Length))@(booking.Description.Length > 100 ? "..." : "")</p>
                                }
                            </div>

                            <div class="d-flex gap-2">
                                <a href="/Booking/Details/@booking.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                                @if (booking.Status != TooDooList.Models.BookingStatus.Cancelled && 
                                     booking.Status != TooDooList.Models.BookingStatus.Completed)
                                {
                                    <a href="/Booking/Update/@booking.Id" class="btn btn-sm btn-outline-warning">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
